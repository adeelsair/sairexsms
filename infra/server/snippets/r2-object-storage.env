# ------------------------------------------------------------------------------
# Cloudflare R2 — paste these into infra/server/server.env.live on the VPS
# (same directory as deploy-safe.sh expects: ENV_FILE_PATH=infra/server/server.env.live)
#
# Do NOT commit real keys. After editing: redeploy, or restart app + workers:
#   docker compose -f infra/server/docker-compose.prod.yml --env-file infra/server/server.env.live restart app worker sms_worker
# ------------------------------------------------------------------------------

AWS_S3_BUCKET=sairexsmsr2
AWS_REGION=auto
S3_ENDPOINT=https://YOUR_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# Public hostname for organization logos (browser + email). Use R2 custom domain or *.r2.dev public URL.
# Recommended on the server (no image rebuild): STORAGE_PUBLIC_BASE_URL
# STORAGE_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# STORAGE_PUBLIC_BASE_URL=https://cdn.yourdomain.com
# Optional duplicate for CI/build-time client code: NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

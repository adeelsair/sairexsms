NODE_ENV=production

# Use image tags from GHCR (latest, sha-<short-sha>, or release tags).
SAIREX_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/sairexsms-ops:latest
SAIREX_APP_DOMAIN=app.sairexsms.com
TRAEFIK_ACME_EMAIL=YOUR_EMAIL@example.com

POSTGRES_USER=sairex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sairex
BACKUP_RETENTION_DAYS=7

DATABASE_URL=postgresql://sairex:CHANGE_ME_STRONG_PASSWORD@db:5432/sairex
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

SMS_QUEUE_NAME=sms_queue
SMS_WORKER_CONCURRENCY=5
SMS_RATE_LIMIT_WINDOW_SEC=60
SMS_RATE_LIMIT_MAX_PER_TENANT=100
SMS_RATE_LIMIT_MAX_PER_RECIPIENT=3

NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
NEXTAUTH_URL=https://YOUR_DOMAIN
NEXT_TELEMETRY_DISABLED=1

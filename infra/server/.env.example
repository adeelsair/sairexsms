NODE_ENV=production

# Use image tags from GHCR (latest, sha-<short-sha>, or release tags).
SAIREX_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/sairexsms-ops:latest
SAIREX_APP_DOMAIN=app.sairexsms.com
TRAEFIK_ACME_EMAIL=YOUR_EMAIL@example.com
# Edge routing mode for deploy safety checks:
# - nginx: require app published on 127.0.0.1:3000
# - traefik: require traefik container running
# - auto: accept either (recommended for mixed setups)
EDGE_ROUTER_MODE=auto

POSTGRES_USER=sairex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sairex
BACKUP_RETENTION_DAYS=7

DATABASE_URL=postgresql://sairex:CHANGE_ME_STRONG_PASSWORD@db:5432/sairex
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# --- Auth + verification parity ---
# Must be your public app URL so verification links work in email.
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
NEXTAUTH_URL=https://YOUR_DOMAIN
AUTH_EMAIL_DELIVERY_MODE=queue
NEXT_TELEMETRY_DISABLED=1

# --- App entry vs marketing (host-based `/`) ---
# Optional: link to marketing site from app entry navbar
# NEXT_PUBLIC_MARKETING_SITE_URL=https://sairex-sms.com
# Optional: extra hosts that show app entry at / (e.g. localhost for dev)
# APP_ENTRY_HOSTS=

# --- SMTP (email verification / auth emails) ---
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=YOUR_SMTP_USERNAME
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=no-reply@YOUR_DOMAIN
SMTP_FROM_NAME=SAIREX SMS

# --- SMS provider (OTP verification) ---
# Choose one: veevo | smsmobileapi
SMS_PROVIDER=veevo
# Set to 0/unset in production. 1/true/yes only logs SMS without sending.
SMS_DRY_RUN=0

# Veevo
VEEVO_HASH=YOUR_VEEVO_HASH
VEEVO_SENDER=YOUR_VEEVO_SENDER

# SMSMobileAPI
SMSMOBILE_API_KEY=
SMSMOBILE_API_URL=https://api.smsmobileapi.com/sendsms/
# SMSMobileAPI behavior toggles
SMSMOBILE_SEND_SMS=1
SMSMOBILE_SEND_WA=

SMS_QUEUE_NAME=sms_queue
SMS_WORKER_CONCURRENCY=5
SMS_RATE_LIMIT_WINDOW_SEC=60
SMS_RATE_LIMIT_MAX_PER_TENANT=100
SMS_RATE_LIMIT_MAX_PER_RECIPIENT=3

# --- Stack backup dashboard (Next app; SUPER_ADMIN only) ---
# Mount the host backup directory read-only into the app container, then set the in-container path:
# BACKUP_ARCHIVE_DIR=/var/backups/sairex-stack
# Optional: override path to backup-last-run.json (default: ${BACKUP_ARCHIVE_DIR}/backup-last-run.json)
# BACKUP_STATUS_FILE=
# Optional: path for disk-usage widget in admin Backups (default: /). Use same mount as disk-alert.sh cares about.
# BACKUP_DISK_STAT_PATH=/

# --- Optional: Telegram from host cron (backup-stack.sh / disk-alert.sh via telegram-notify.sh) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_NOTIFY_SUCCESS=true

# Copy to `.env.local` for `npm run dev` (Next.js loads .env.local).
# Production: set the same variables on the server (e.g. infra/server `.env` for Docker).

# --- Cloudflare R2 (S3 API) — production bucket: sairexsmsr2 ---
AWS_S3_BUCKET=sairexsmsr2
AWS_REGION=auto
S3_ENDPOINT=https://YOUR_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# Public URL for logos (server runtime, no rebuild): preferred on production VPS
# STORAGE_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# NEXT_PUBLIC_CDN_URL=https://pub-xxxxx.r2.dev

# If unset, onboarding certificates/logos fall back to data URLs (dev only).
